{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "types": ["vite/client", "node"],
    "paths": {
      "@/*": ["./src/*"],
      "@linex/shared": ["../shared/src/index.ts"],
      "@linex/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"]
}
