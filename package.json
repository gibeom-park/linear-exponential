{
  "name": "linear-exponential",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,magenta \"pnpm --filter frontend dev\" \"pnpm --filter backend dev\"",
    "build": "pnpm -r build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter backend db:generate",
    "db:migrate:local": "pnpm --filter backend db:migrate:local",
    "db:migrate:remote": "pnpm --filter backend db:migrate:remote",
    "db:seed:local": "pnpm --filter backend db:seed:local",
    "db:seed:remote": "pnpm --filter backend db:seed:remote",
    "deploy": "pnpm --filter frontend build && pnpm --filter backend run deploy"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "concurrently": "^9.1.0",
    "dotenv-cli": "^7.4.4",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "sharp", "workerd"]
  }
}
